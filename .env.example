# Lupus training infrastructure environment variables
#
# Copy this file to .env and fill in your values:
#     cp .env.example .env
#
# .env is gitignored — NEVER commit credentials.
#
# This file is used both on your local workstation (for pushing dataset
# and pulling final models) and on the RunPod GPU instance (for pulling
# dataset, downloading base models, pushing checkpoints).

# ============================================================
# RunPod S3-compatible storage
# ============================================================
# Used for: dataset upload, training checkpoints, final model export
#
# Get S3 credentials from:
#   RunPod console → User Settings → S3 API Keys → Create
#   (or via the network volume's "S3 Credentials" tab)
#
# These are AWS_-prefixed so boto3 picks them up automatically without
# extra config. RunPod's S3 implementation is AWS S3 protocol-compatible.

S3_ENDPOINT_URL=https://s3api-us-il-1.runpod.io
S3_BUCKET=7oqdtnkk5f
AWS_ACCESS_KEY_ID=your-runpod-s3-access-key-id
AWS_SECRET_ACCESS_KEY=your-runpod-s3-secret-access-key
AWS_DEFAULT_REGION=us-il-1

# ============================================================
# HuggingFace Hub
# ============================================================
# Used for: downloading base models on the RunPod instance.
#   - TinyAgent-1.1B (search adapter base)
#   - Qwen2.5-Coder-0.5B (security model base)
# Both are publicly available so a token isn't strictly required, but
# tokens improve download rate limits and avoid intermittent throttling
# on busy days.
#
# Get from: https://huggingface.co/settings/tokens
#   → Create a "Read" token (no special permissions needed)

HF_TOKEN=your-huggingface-token

# ============================================================
# Weights & Biases (optional but strongly recommended)
# ============================================================
# Used for: experiment tracking, loss curves, hyperparameter logging,
# resumable training visualization across spot interruptions.
#
# Get API key from: https://wandb.ai/authorize
# Free tier is plenty for personal/research use.
#
# To skip W&B entirely, set WANDB_DISABLED=true and leave the others empty.

WANDB_API_KEY=your-wandb-api-key
WANDB_PROJECT=lupus
WANDB_ENTITY=your-wandb-username
# WANDB_DISABLED=true  # uncomment to disable W&B

# ============================================================
# PhishTank API key (optional)
# ============================================================
# Only needed if you want to use PhishTank's bulk phishing CSV download
# instead of (or in addition to) the free OpenPhish feed.
#
# Register at: https://phishtank.org/
#   → Create account → Application Keys → Request a key (free, instant)

# PHISHTANK_API_KEY=your-phishtank-application-key

# ============================================================
# RunPod API key (optional, for pod automation)
# ============================================================
# Only needed if you want to programmatically create/destroy/monitor
# RunPod instances from local scripts. Not required if you manage pods
# manually through the web console.
#
# Get from: https://www.runpod.io/console/user/settings → API Keys

# RUNPOD_API_KEY=your-runpod-api-key
