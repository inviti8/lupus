# Model weights (too large for git)
*.gguf
*.bin
*.safetensors
*.pt
*.pth
checkpoints/
dist/

# Training artifacts
wandb/
runs/
*.log
training/output/

# Python
__pycache__/
*.pyc
.venv/
*.egg-info/

# Rust build artifacts
target/

# Data (downloaded, not committed)
datasets/raw/
datasets/downloaded/

# Security dataset: ignore downloaded raw data and built JSONL examples,
# but preserve directory structure via .gitkeep
datasets/security/raw/*
!datasets/security/raw/.gitkeep
datasets/security/examples/*.jsonl

# Environment
.env

# IDE / editor settings
.claude/
.vscode/
.idea/

.env.env.us-il-1.bak

# TinyAgent eval runs: ignore everything in eval/tinyagent_runs/ except
# the reference runs that findings docs explicitly cite. Future runs are
# reproducible via tools/eval_tinyagent.py and don't need to be committed
# unless they're worth referencing in docs.
eval/tinyagent_runs/*.jsonl
eval/tinyagent_runs/*.log
!eval/tinyagent_runs/20260407-225450-eval.jsonl
!eval/tinyagent_runs/20260407-232422-eval.jsonl
!eval/tinyagent_runs/20260408-111025-eval.jsonl
